# Copy this file to .env and fill in your keys.
# The .env file is listed in .gitignore so it will never be committed.

# Groq — get your free key at https://console.groq.com
GROQ_API_KEY=your-groq-key-here

# Supabase — get these from your project's API Keys page
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SECRET_KEY=your-secret-key-here

# Flask — any long random string, used to sign session cookies
FLASK_SECRET_KEY=change-this-to-a-long-random-string
